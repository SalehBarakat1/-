    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* إعدادات التصميم العامة */
        :root {
            --primary-color: #c5a880; /* لون ذهبي دافئ للكافيهات */
            --bg-dark: #121212;
            --bg-card: #1e1e1e;
            --text-light: #f5f5f5;
            --text-muted: #b3b3b3;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Cairo', sans-serif;
        }

        body { 
            background-color: var(--bg-dark);
            color: var(--text-light);
            line-height: 1.6;
        } 

        header {
            background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?q=80&w=1600') no-repeat center center/cover;
            height: 40vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            border-bottom: 3px solid var(--primary-color);
            padding: 20px;
        }

        header h1 {
            font-size: 3.5rem;
            color: var(--primary-color);
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.6);
            letter-spacing: 2px;
        }


        header p {
            font-size: 1.2rem;
            color: var(--text-light);
            max-width: 600px;
        }

        /* الحاوية الرئيسية للمنيو */
        .menu-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
        }

        /* عناوين الأقسام */
        .section-title {
            text-align: center;
            font-size: 2.2rem;
            color: var(--primary-color);
            margin: 50px 0 30px 0;
            position: relative;
            padding-bottom: 10px;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 3px;
            background-color: var(--primary-color);
            border-radius: 2px;
        }

        /* شبكة المنتجات */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
        }

        /* كارت المنتج */
        .menu-item {
            background-color: var(--bg-card);
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid #2a2a2a;
        }

        .menu-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(197, 168, 128, 0.2);
            border-color: var(--primary-color);
        }

        /* صور المنتجات */
        .item-image {
            width: 100%;
            height: 220px;
            overflow: hidden;
            position: relative;
        }

        .item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .menu-item:hover .item-image img {
            transform: scale(1.1);
        }

        /* تفاصيل المنتج */
        .item-info {
            padding: 20px;
            text-align: center;
        }

        .item-info h3 {
            font-size: 1.3rem;
            color: var(--text-light);
            margin-bottom: 8px;
        }

        .item-info p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 15px;
        }

        .item-price {
            color: var(--primary-color);
            font-weight: bold;
            font-size: 1.2rem;
            display: block;
        }

        /* الفوتر (أسفل الصفحة) */
        footer {
            background-color: #0b0b0b;
            text-align: center;
            padding: 30px;
            margin-top: 60px;
            border-top: 1px solid #222;
        }

        footer p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        
        footer span {
            color: var(--primary-color);
            font-weight: bold;
        }
    </style>
</head>
